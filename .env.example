# agent-loopa provider API keys
# Only set keys for the providers you actually use.
# litellm reads these automatically — no hardcoded keys anywhere.

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google / Gemini
GEMINI_API_KEY=...

# Mistral
MISTRAL_API_KEY=...

# Azure OpenAI (optional)
AZURE_API_KEY=...
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-02-01

# Local Ollama (optional — no key required)
OLLAMA_API_BASE=http://localhost:11434
